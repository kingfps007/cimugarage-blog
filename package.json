{
  "name": "cimugarage-blog",
  "version": "0.1.0",
  "private": false,
  "description": "此木的车间·cimugarage.cn——个人博客静态站",
  "hexo": {
    "version": "7.3.0"
  },
  "scripts": {
    "prebuild": "git submodule update --init --recursive",
    "build": "hexo generate",
    "postbuild": "node tools/copy-redirects.js",
    "clean": "hexo clean",
    "server": "hexo server",
    "deploy": "echo 'ESA Pages 自动部署，推 git 即可' && exit 0",
    "lint": "eslint tools/",
    "check:pre-push": "bash tools/pre-push-check.sh"
  },
  "engines": {
    "node": ">=20.0.0 <21.0.0",
    "npm": ">=10.0.0 <11.0.0"
  },
  "keywords": [
    "hexo",
    "blog",
    "cimugarage",
    "static-site"
  ],
  "author": "此木的车间 <2479010668@qq.com>",
  "license": "MIT",
  "dependencies": {
    "hexo": "^7.3.0",
    "hexo-generator-archive": "^2.0.0",
    "hexo-generator-category": "^2.0.0",
    "hexo-generator-feed": "^3.0.0",
    "hexo-generator-sitemap": "^3.0.1",
    "hexo-generator-tag": "^2.0.0",
    "hexo-renderer-ejs": "^2.0.0",
    "hexo-renderer-marked": "^6.3.0",
    "hexo-renderer-stylus": "^3.0.1",
    "hexo-server": "^3.0.0"
  },
  "devDependencies": {
    "eslint": "^10.6.0",
    "prettier": "^3.3.0"
  }
}
