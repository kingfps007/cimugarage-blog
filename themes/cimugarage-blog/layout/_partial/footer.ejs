<%
// 底部 footer：备案号 + 版权 + 双语切换（次级）
var lang = page.lang || (config.language === 'zh-CN' ? 'zh-CN' : 'en');
var isEn = lang === 'en';
var year = new Date().getFullYear();
var since = config.since || theme.site.since || year;
var yearText = since === year ? String(year) : since + '–' + year;
%>
<footer class="site-footer" role="contentinfo">
  <div class="container footer-inner">
    <p class="copyright">
      © <%= yearText %> <%= theme.site.author %>.
      <a href="<%= theme.license_url || 'https://creativecommons.org/licenses/by/4.0/' %>" rel="license">CC BY 4.0</a>
    </p>
    <p class="beian">
      <a href="<%= theme.beian_url || 'https://beian.miit.gov.cn/' %>" target="_blank" rel="noopener noreferrer">
        <%= theme.icp %>
      </a>
      <% if (theme.police) { %>
        <span class="sep">·</span>
        <a href="https://beian.mps.gov.cn/" target="_blank" rel="noopener noreferrer">
          <%= theme.police %>
        </a>
      <% } %>
    </p>
  </div>
</footer>
