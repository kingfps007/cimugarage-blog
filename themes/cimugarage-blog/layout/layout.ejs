<!DOCTYPE html>
<html lang="<%= page.lang || (config.language === 'zh-CN' ? 'zh-CN' : 'en') %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%
  var siteUrl = (config.url || theme.site.url || '').replace(/\/+$/, '');
  var pageTitle = page.title || theme.site.title;
  var fullTitle = (page.layout === 'index') ? theme.site.title : pageTitle + ' · ' + theme.site.title;
  var pageType = page.layout === 'post' ? 'article' : 'website';
  var pagePath = (page.path || '').replace(/^\/+/, '');
  var pageURL = siteUrl + '/' + pagePath;
  // 清理末尾多余的 /
  pageURL = pageURL.replace(/\/+$/, '/');
  %>
  <title><%= fullTitle %></title>
  <meta name="description" content="<%= page.description || page.excerpt || theme.site.description %>">
  <meta name="author" content="<%= theme.site.author %>">

  <!-- 暗色模式：页面加载前应用，避免闪烁 -->
  <script>
    (function() {
      try {
        var key = 'cimu-dark';
        var saved = localStorage.getItem(key);
        var mode = saved || '<%= theme.dark_mode.default %>';
        if (mode === 'dark') document.documentElement.classList.add('dark');
      } catch (e) {}
    })();
  </script>

  <!-- hreflang 双语 -->
  <% if (page.path && page.layout !== 'index') {
       var cleanPath = page.path.replace(/^\/+/, '').replace(/\/+$/, '');
       // 去掉语言前缀 en/
       if (cleanPath === 'en') {
         cleanPath = '';
       } else if (cleanPath.indexOf('en/') === 0) {
         cleanPath = cleanPath.substring(3);
       }
       var isEn = page.lang === 'en';
       var enPath = cleanPath ? 'en/' + cleanPath : 'en';
       var zhPath = cleanPath;
       // 是否是文件型 URL（带 .html/.xml 等扩展名）→ 不加尾 /
       var isFileURL = cleanPath && /\.[a-z]+$/i.test(cleanPath);
       var zhSuffix = isFileURL ? '' : (zhPath ? '/' : '');
       var enSuffix = isFileURL ? '' : '/';
  %>
    <link rel="alternate" hreflang="zh-CN" href="<%= siteUrl %>/<%= zhPath %><%= zhSuffix %>">
    <link rel="alternate" hreflang="en" href="<%= siteUrl %>/<%= enPath %><%= enSuffix %>">
    <link rel="alternate" hreflang="x-default" href="<%= siteUrl %>/<%= zhPath %><%= zhSuffix %>">
    <link rel="canonical" href="<%= pageURL %>">
  <% } %>

  <!-- OG / Twitter -->
  <% var ogImage = page.cover || theme.cover_placeholder; %>
  <meta property="og:type" content="<%= pageType %>">
  <meta property="og:title" content="<%= pageTitle %>">
  <meta property="og:description" content="<%= page.description || page.excerpt || theme.site.description %>">
  <meta property="og:url" content="<%= pageURL %>">
  <meta property="og:locale" content="<%= (page.lang === 'en') ? 'en_US' : 'zh_CN' %>">
  <meta property="og:image" content="<%= siteUrl %><%= ogImage %>">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= pageTitle %>">
  <meta name="twitter:description" content="<%= page.description || page.excerpt || theme.site.description %>">
  <meta name="twitter:image" content="<%= siteUrl %><%= ogImage %>">

  <!-- favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="apple-touch-icon" href="<%= siteUrl %><%= config.apple_touch_icon || '/assets/images/common/apple-touch-icon.png' %>">

  <!-- 主题 CSS -->
  <link rel="stylesheet" href="/css/style.css">

  <!-- JSON-LD -->
  <%
  var jsonldType = 'WebPage';
  if (page.layout === 'index') jsonldType = 'WebSite';
  else if (page.layout === 'post') jsonldType = 'BlogPosting';
  %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "<%= jsonldType %>",
    "name": "<%= theme.site.title %>",
    "url": "<%= siteUrl %>",
    "headline": "<%= pageTitle %>",
    "description": "<%= page.description || page.excerpt || theme.site.description %>",
    "inLanguage": "<%= page.lang || (config.language === 'zh-CN' ? 'zh-CN' : 'en') %>"
    <% if (page.layout === 'post') { %>, "datePublished": "<%= page.date.toISOString() %>", "dateModified": "<%= (page.updated || page.date).toISOString() %>"<% } %>
  }
  </script>
</head>
<body>
  <a href="#main-content" class="skip-link">跳到主内容</a>

  <%- partial('_partial/header') %>

  <main id="main-content" class="main" role="main" tabindex="-1">
    <%- body %>
  </main>

  <%- partial('_partial/footer') %>

  <!-- 主题切换 JS -->
  <script src="/js/theme-toggle.js" defer></script>
</body>
</html>
