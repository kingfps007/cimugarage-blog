<%
// 博客首页：最新文章列表（仅 layout: post 的真实博客文章）
var posts = site.posts.filter(function(p) { return p.layout === 'post'; });
var perPage = theme.home_posts_per_page || 10;
var paged = posts.sort('-date').limit(perPage);
var lang = page.lang || (config.language === 'zh-CN' ? 'zh-CN' : 'en');
var isEn = lang === 'en';
%>

<div class="container">
  <section class="home-hero">
    <h1 class="site-title"><%= theme.site.title %></h1>
    <p class="site-subtitle"><%= theme.site.subtitle %></p>
  </section>

  <% if (theme.last_updated_warning > 0) { %>
    <% paged.forEach(function(post) {
         var updated = (post.updated || post.date);
         var updatedMs = (updated && updated.valueOf) ? updated.valueOf() : (updated ? updated.getTime() : Date.now());
         var days = Math.floor((Date.now() - updatedMs) / 86400000);
         if (days > theme.last_updated_warning) { %>
           <div class="outdated-warning">
             <%= isEn ? 'Last updated ' : '最后更新于 ' %><%= date(updated, 'YYYY-MM-DD') %><%= isEn ? ', ' + days + ' days ago. ' : '，距今 ' + days + ' 天。' %>
           </div>
    <%   }
       }); %>
  <% } %>

  <section class="post-list" aria-label="<%= isEn ? 'Latest posts' : '最新文章' %>">
    <% if (paged.length === 0) { %>
      <p class="empty"><%= isEn ? 'No posts yet. Stay tuned.' : '暂无文章，敬请期待。' %></p>
    <% } else { %>
      <% paged.forEach(function(post) { %>
        <article class="post-card">
          <% if (post.cover) { %>
            <a class="post-card-cover" href="<%= url_for(post.path) %>" aria-hidden="true" tabindex="-1">
              <img src="<%= post.cover %>" alt="" loading="lazy">
            </a>
          <% } %>
          <div class="post-card-body">
            <h2 class="post-card-title">
              <a href="<%= url_for(post.path) %>"><%= post.title %></a>
            </h2>
            <p class="post-card-meta">
              <time datetime="<%= post.date.toISOString() %>"><%= date(post.date, 'YYYY-MM-DD') %></time>
              <% if (post.category) { %>
                <span class="sep">·</span>
                <a class="cat" href="<%= url_for(post.category.path) %>"><%= post.category.name %></a>
              <% } %>
            </p>
            <% if (post.description || post.excerpt) { %>
              <p class="post-card-excerpt"><%= post.description || strip_html(post.excerpt).substring(0, 140) %></p>
            <% } %>
          </div>
        </article>
      <% }); %>
    <% } %>
  </section>
</div>
