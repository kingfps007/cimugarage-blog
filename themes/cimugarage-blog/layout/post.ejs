<%
// 单篇文章页
var lang = page.lang || (config.language === 'zh-CN' ? 'zh-CN' : 'en');
var isEn = lang === 'en';

// 计算最后更新天数
var updated = page.updated || page.date;
var updatedMs = (updated && updated.valueOf) ? updated.valueOf() : (updated ? updated.getTime() : Date.now());
var days = Math.floor((Date.now() - updatedMs) / 86400000);
var showOutdated = theme.last_updated_warning > 0 && days > theme.last_updated_warning;
%>

<article class="post post-detail" itemscope itemtype="https://schema.org/BlogPosting">
  <div class="container">

    <% if (showOutdated) { %>
      <div class="outdated-warning">
        <%= isEn ? 'Last updated ' : '最后更新于 ' %><%= date(updated, 'YYYY-MM-DD') %><%= isEn ? ', ' + days + ' days ago. ' : '，距今 ' + days + ' 天。' %>
      </div>
    <% } %>

    <header class="post-header">
      <h1 class="post-title" itemprop="headline"><%= page.title %></h1>
      <p class="post-meta">
        <time datetime="<%= page.date.toISOString() %>" itemprop="datePublished"><%= date(page.date, 'YYYY-MM-DD') %></time>
        <% if (page.updated) { %>
          <span class="sep">·</span>
          <span><%= isEn ? 'Updated ' : '更新 ' %><time datetime="<%= page.updated.toISOString() %>" itemprop="dateModified"><%= date(page.updated, 'YYYY-MM-DD') %></time></span>
        <% } %>
        <% if (page.category) { %>
          <span class="sep">·</span>
          <a class="cat" href="<%= url_for(page.category.path) %>" itemprop="articleSection"><%= page.category.name %></a>
        <% } %>
        <% if (page.tags && page.tags.length) { %>
          <span class="sep">·</span>
          <span class="tags" itemprop="keywords">
            <% page.tags.forEach(function(tag, i) { %>
              <a href="<%= url_for(tag.path) %>">#<%= tag.name %></a><%= i < page.tags.length - 1 ? ' ' : '' %>
            <% }); %>
          </span>
        <% } %>
      </p>
      <% if (page.license) { %>
        <p class="post-license">
          <a href="https://creativecommons.org/licenses/by/4.0/" rel="license"><%= page.license %></a>
        </p>
      <% } %>
    </header>

    <% if (page.cover) { %>
      <figure class="post-cover">
        <img src="<%= page.cover %>" alt="<%= page.cover_caption || page.title %>" loading="lazy" itemprop="image">
        <% if (page.cover_caption) { %>
          <figcaption><%= page.cover_caption %></figcaption>
        <% } %>
      </figure>
    <% } %>

    <div class="post-content" itemprop="articleBody">
      <%- page.content %>
    </div>

    <% if (page.description) { %>
      <p class="post-description"><%= isEn ? 'Summary: ' : '摘要：' %><%= page.description %></p>
    <% } %>
  </div>
</article>
